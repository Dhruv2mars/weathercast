NODE_ENV=development
PORT=8787
DATABASE_PATH=.data/weathercast.sqlite
NOWCAST_PROVIDER_MODE=open-meteo-evaluation
OPEN_METEO_API_HOST=https://api.open-meteo.com
CORS_ORIGIN=*
RATE_LIMIT_PER_MINUTE=120
FORECAST_CACHE_SECONDS=240
UPSTREAM_TIMEOUT_MS=8000

# Production-only licensed/provider blender:
# NOWCAST_PROVIDER_MODE=normalized-upstream
# NORMALIZED_UPSTREAM_URL=https://provider.example/v1/normalized-point
# NORMALIZED_UPSTREAM_TOKEN=replace-with-server-only-secret
