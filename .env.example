# Required for commercial distribution. Do not place provider secrets in EXPO_PUBLIC variables.
EXPO_PUBLIC_NOWCAST_API_URL=https://api.weathercast.example

# Optional licensed radar manifest consumed by the Radar screen.
EXPO_PUBLIC_RADAR_MANIFEST_URL=https://radar.weathercast.example/v1/manifest.json

# Required to render Google Maps in Android builds. Restrict this key to the Android app ID and signing certificate.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=replace-with-a-restricted-android-key

# Evaluation fallback only.
EXPO_PUBLIC_OPEN_METEO_HOST=https://api.open-meteo.com
